# Verbose example covering the same Service Account case as main.tf, but
# spelling out every optional attribute the resource exposes. Use this as a
# reference when you need to deviate from defaults.

resource "mongodbatlas_api_resource" "verbose" {
  path         = "/api/atlas/v2/orgs/${var.org_id}/serviceAccounts"
  id_attribute = ["clientId"]

  # HTTP method overrides — defaults shown.
  create_method = "POST"
  update_method = "PATCH"

  # API version negotiation. When unset, the resource captures today's UTC
  # date at Create and persists it in state for the lifetime of the resource.
  # Set explicitly to pin a known Atlas API release date.
  # Set `preview = true` instead to use application/vnd.atlas.preview+json.
  version_header = "application/vnd.atlas.2024-08-05+json"
  preview        = false

  # Body keys that the endpoint accepts only on Create and rejects on Update.
  create_only_body_keys = ["secretExpiresAfterHours"]

  body = {
    name                    = "example-generic-sa"
    description             = "Service account managed via mongodbatlas_api_resource"
    roles                   = ["ORG_READ_ONLY"]
    secretExpiresAfterHours = 24
  }

  # Sensitive fragment merged into the body at Create/Update.
  # Values are never written to state and excluded from drift comparison.
  sensitive_body = {
    # Example only — service accounts have no sensitive body fields.
    # third_party_token = var.third_party_token
  }
}

data "mongodbatlas_api_resource" "verbose" {
  path           = mongodbatlas_api_resource.verbose.id
  version_header = "application/vnd.atlas.2024-08-05+json"
}
